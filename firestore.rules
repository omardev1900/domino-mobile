rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction helper : vérifie si l'utilisateur connecté est admin (superadmin ou manager)
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Fonction helper : vérifie si l'utilisateur connecté est superadmin
    function isSuperAdmin() {
      let adminData = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        (!('role' in adminData) || adminData.role == 'superadmin');
    }

    // Collection admins : chaque admin peut lire son propre doc, superadmin peut lire tous les docs
    match /admins/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());
      allow write: if false; // Jamais modifiable depuis le client (via API routes + SDK Admin)
    }

    // Règle pour la collection des bots
    match /bots/{botId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Boutique (Store) : Un joueur peut VOIR le catalogue, mais NE DOIT PAS le modifier.
    match /store_catalog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Règle pour les Rooms de jeu
    match /rooms/{roomId} {
      function isRoomMember() {
        return request.auth != null &&
          (request.auth.uid in resource.data.playerIds || request.auth.uid in request.resource.data.playerIds);
      }

      function onlyPlayerStatusChanged(before, after) {
        return before.id == after.id &&
          after.diff(before).affectedKeys().hasOnly(['status']) &&
          (
            before.status == after.status ||
            (
              before.id == request.auth.uid &&
              before.status != 'BOT' &&
              after.status in ['HUMAN', 'DISCONNECTED', 'SURRENDERED']
            ) ||
            (
              before.id != request.auth.uid &&
              before.status == 'HUMAN' &&
              after.status == 'DISCONNECTED'
            )
          );
      }

      function isPresenceOnlyGameStateUpdate() {
        let before = resource.data.gameState;
        let after = request.resource.data.gameState;
        return before != null && after != null &&
          after.diff(before).affectedKeys().hasOnly(['players']) &&
          before.players.size() == after.players.size() &&
          before.players.size() <= 3 &&
          (before.players.size() < 1 || onlyPlayerStatusChanged(before.players[0], after.players[0])) &&
          (before.players.size() < 2 || onlyPlayerStatusChanged(before.players[1], after.players[1])) &&
          (before.players.size() < 3 || onlyPlayerStatusChanged(before.players[2], after.players[2]));
      }

      function isCoordinatorLobbyStart() {
        return resource.data.status == 'WAITING' &&
          resource.data.gameState == null &&
          request.resource.data.status == 'PLAYING' &&
          request.resource.data.gameState != null &&
          request.auth.uid == resource.data.createdBy;
      }

      function respectsCoordinatorAuthority() {
        return resource.data.get('coordinatorVersion', 0) != 1 ||
          request.resource.data.gameState == resource.data.gameState ||
          isCoordinatorLobbyStart() ||
          (resource.data.status != 'WAITING' && isPresenceOnlyGameStateUpdate());
      }
      // Admin : accès complet
      allow read, write: if isAdmin();

      // Joueurs : création et lecture
      allow read, create: if request.auth != null;

      // Un joueur ne peut mettre à jour que s'il est dans la room (ou s'y ajoute)
      allow update: if isRoomMember() && respectsCoordinatorAuthority();

      // Seul le créateur (host) peut supprimer la room, OU la room est vide (plus de joueurs)
      allow delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || resource.data.playerIds.size() == 0);
    }

    // Tournois : lecture publique (pour l'app mobile), écriture admin uniquement
    match /tournaments/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      // Les joueurs peuvent écrire leur propre document participant (pour rejoindre)
      match /participants/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Logs des actions admin : écriture par les admins authentifiés, lecture superadmin uniquement
    match /admin_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Les logs sont immuables
    }

    // Logs système (Cloud Functions) : lecture superadmin uniquement.
    // Écriture réservée aux Cloud Functions via Admin SDK (qui bypasse les rules).
    match /system_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Actualités (News) : Lecture pour tous, écriture pour les admins
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Publicités (Ads) — Phase 1 : popup admin-managed.
    // Lecture publique (mobile charge la liste au démarrage), écriture admin uniquement.
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages et emojis du tchat en jeu.
    // Lecture authentifiée (mobile), écriture admin uniquement.
    match /chat_messages/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Feedbacks utilisateurs (envoyés depuis le bouton MDC dans la sidebar)
    // Tout joueur authentifié peut créer un feedback. Lecture/modification superadmin uniquement.
    match /feedbacks/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isSuperAdmin();
      allow update: if isSuperAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow delete: if false;
    }

    // Configuration globale du jeu
    match /config/{docId} {
      allow read: if request.auth != null; // Lecture par tous (utile pour le mobile)
      allow write: if isSuperAdmin();
    }

    // Règle pour les profils utilisateurs
    match /users/{userId} {
      // Superadmin : accès complet (lecture + modification pour bannissement, coins, etc.)
      allow read, write: if isSuperAdmin();

      // Joueur : lecture de tous, écriture uniquement de son profil
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Règle pour les statistiques mensuelles des utilisateurs (leaderboard)
    match /users_monthly_stats/{statId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource == null 
          ? request.resource.data.userId == request.auth.uid 
          : (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid));
    }
  }
}
