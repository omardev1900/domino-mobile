rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Actualités — lecture publique, écriture admin authentifié
    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Avatars bots IA — uploadés depuis l'admin
    match /bots/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Avatars boutique — uploadés depuis l'admin
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Audio — musiques uploadées depuis l'admin
    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Autres fichiers (par défaut : accès refusé)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
