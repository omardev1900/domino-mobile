rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Configuration de l'app (Lecture seule pour tous)
    match /config/{docId} {
      allow read: if true;
      allow write: if false; 
    }

    // Profiles et Économie
    match /users/{userId} {
      allow read: if true;
      // Seul l'utilisateur peut modifier son propre profil (displayName, avatarId)
      // L'économie (coins, xp) devrait idéalement passer par des Functions (SEC-3)
      // mais en attendant, on restreint au propriétaire.
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Salles de jeu
    match /rooms/{roomId} {
      allow read: if true;
      // N'importe quel utilisateur authentifié peut créer une salle
      allow create: if request.auth != null;
      // N'importe quel utilisateur dans la salle peut mettre à jour l'état du jeu
      // (Sécurité simplifiée pour l'instant)
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.hostId == request.auth.uid || resource.data.playerIds.size() == 0);
    }
    
    // Statistiques globales
    match /stats/{docId} {
      allow read: if true;
      allow write: if false; // Lecture seule pour le client
    }
  }
}
