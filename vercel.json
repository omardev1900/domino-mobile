{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci --prefix mobile",
  "buildCommand": "npm run build:web --prefix mobile",
  "outputDirectory": "mobile/dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/policy",
      "destination": "https://domino-martinique.online/policy",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "https://domino-martinique.online/policy",
      "permanent": true
    },
    {
      "source": "/politique-de-confidentialite",
      "destination": "https://domino-martinique.online/policy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
